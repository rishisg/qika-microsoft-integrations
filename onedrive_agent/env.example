# Microsoft Graph OAuth credentials (same app registration as Outlook)
ONEDRIVE_CLIENT_ID=your-azure-app-client-id
ONEDRIVE_CLIENT_SECRET=your-azure-app-client-secret
ONEDRIVE_TENANT_ID=common
ONEDRIVE_REDIRECT_URI=http://localhost:8011/onedrive/oauth/callback
ONEDRIVE_TOKEN_STORE_PATH=./local_secrets/default_tenant/onedrive_tokens.json

HOST=0.0.0.0
PORT=8011
ONEDRIVE_LOG_LEVEL=INFO
ONEDRIVE_LOG_FORMAT=json
