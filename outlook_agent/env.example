# Microsoft Graph OAuth credentials
# Get these from portal.azure.com → App registrations
OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_CLIENT_SECRET=your-azure-app-client-secret

# Use "common" to support both personal (Hotmail) and org (M365) accounts
OUTLOOK_TENANT_ID=common

# Redirect URI registered in Azure portal
OUTLOOK_REDIRECT_URI=http://localhost:8010/outlook/oauth/callback

# Token storage path (local file for dev)
OUTLOOK_TOKEN_STORE_PATH=./local_secrets/default_tenant/outlook_tokens.json

# Server settings
HOST=0.0.0.0
PORT=8010

# Logging
OUTLOOK_LOG_LEVEL=INFO
OUTLOOK_LOG_FORMAT=json
